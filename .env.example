# =====================================================================
# TNT SRE War-Room Lab — 환경 변수 템플릿
# 사용법:  cp .env.example .env   후 값 채우기.  .env 는 .gitignore 됨(커밋 금지).
# up.sh / down.sh 가 이 파일을 자동으로 읽는다.
# =====================================================================

# ── Slack Incoming Webhook URL 3개 (채널당 1개) ──
# 발급법:
#   https://api.slack.com/apps  >  "Create New App"  >  "From scratch"  >
#   왼쪽 메뉴 "Incoming Webhooks"  >  토글 ON  >
#   "Add New Webhook to Workspace"  >  게시할 채널 선택  >
#   생성된 https://hooks.slack.com/services/XXX/YYY/ZZZ URL 을 아래에 붙여넣기.
#   (채널 3개에 대해 "Add New Webhook to Workspace" 를 각각 반복)
# (Task 4 를 끝내기 전까지는 비워둬도 된다. 비어 있으면 slack-relay 가 전송을 건너뛴다.)
SLACK_WEBHOOK_ALERTS_CRITICAL=""
SLACK_WEBHOOK_INCIDENT_WAR_ROOM=""
SLACK_WEBHOOK_ARCHITECTURE_RFC=""

# ── GCP / Terraform ──
GCP_PROJECT_ID="tih-testproject"
GCP_REGION="asia-northeast3"
GCP_ZONE="asia-northeast3-a"
CLUSTER_NAME="tnt-warroom"

# 인증: 둘 중 하나만 쓰면 된다.
#   (A) gcloud ADC :  gcloud auth application-default login  실행 후 이 값은 빈 문자열로 둔다.
#   (B) 서비스계정 키 : 키 JSON 파일의 절대경로를 넣는다.
GOOGLE_APPLICATION_CREDENTIALS=""

# ── (선택) ArgoCD GitOps ──
# up.sh --with-argocd 사용 시에만 필요. ArgoCD Application 이 동기화할 Git 저장소.
GITOPS_REPO_URL=""
GITOPS_REPO_REVISION="main"
GITOPS_REPO_PATH="tnt-sre-warroom/gitops"
